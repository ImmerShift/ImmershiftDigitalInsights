{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "General settings and white-labeling configuration for a user/agency.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "logoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email"]
    },
    "Connector": {
      "title": "Platform Connector",
      "description": "OAuth tokens and metadata for external platform integrations.",
      "type": "object",
      "properties": {
        "platformId": { "type": "string" },
        "accountName": { "type": "string" },
        "accountId": { "type": "string" },
        "accessToken": { "type": "string" },
        "refreshToken": { "type": "string" },
        "connectedAt": { "type": "string", "format": "date-time" },
        "lastSyncedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "expired", "revoked", "syncing"] }
      },
      "required": ["platformId", "accessToken", "accountName", "accountId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Store the main user profile and white-labeling settings."
    },
    "/users/{userId}/connectors/{connectorId}": {
      "schema": "Connector",
      "description": "Store sensitive OAuth credentials for external platforms."
    }
  }
}
